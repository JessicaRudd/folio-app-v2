{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "creator"] },
        "isPremium": { "type": "boolean" },
        "bio": { "type": "string" },
        "username": { "type": "string" },
        "profilePrivacy": { "type": "string", "enum": ["private", "public"] },
        "total_storage_used": { "type": "number" },
        "total_folio_count": { "type": "number" },
        "total_postcard_count": { "type": "number" },
        "monthly_postcard_count": { "type": "number" },
        "follower_count": { "type": "number" },
        "following_count": { "type": "number" },
        "folioShareToken": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Publicly visible user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "follower_count": { "type": "number" },
        "following_count": { "type": "number" }
      },
      "required": ["uid", "username"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a postcard",
      "type": "object",
      "properties": {
        "postcardId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postcardId", "userId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a postcard",
      "type": "object",
      "properties": {
        "postcardId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userPhotoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postcardId", "userId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "postcardId": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "fromUserId"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Folio": {
      "title": "Folio",
      "description": "A collection of postcards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "coverImage": { "type": "string", "format": "uri" },
        "visibility": { "type": "string", "enum": ["private", "public"] },
        "privacy": { "type": "string", "enum": ["private", "personal", "public"] },
        "curators": { "type": "object", "additionalProperties": { "type": "string", "enum": ["viewer", "editor"] } },
        "allowedUsers": { "type": "array", "items": { "type": "string" } },
        "folioDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "postcardCount": { "type": "number" },
        "photoCount": { "type": "number" },
        "creatorName": { "type": "string" },
        "creatorUsername": { "type": "string" },
        "folioToken": { "type": "string" }
      },
      "required": ["id", "creatorId", "title"]
    },
    "FolioMetadata": {
      "title": "FolioMetadata",
      "description": "Metadata for a user's entire folio",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "shareToken": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "shareToken"]
    },
    "FolioToken": {
      "title": "FolioToken",
      "description": "A mapping from share token to userId for secure lookup",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "Share": {
      "title": "Share",
      "description": "An access key for a Folio or User Folio",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "folioId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "type": { "type": "string", "enum": ["guest", "curator", "folio"] },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "revoked"] },
        "accessedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "status"]
    },
    "Postcard": {
      "title": "Postcard",
      "description": "A single postcard entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "folioId": { "type": "string" },
        "creatorId": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "caption": { "type": "string" },
        "musicTrack": { "type": "string" },
        "visibilityList": { "type": "array", "items": { "type": "string" } },
        "secureToken": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "postcardDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "folioVisibility": { "type": "string", "enum": ["private", "public"] },
        "folioPrivacy": { "type": "string", "enum": ["private", "personal", "public"] },
        "folioToken": { "type": "string" }
      },
      "required": ["id", "folioId", "creatorId", "mediaUrls", "secureToken"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/public_profiles/{username}": {
      "schema": "PublicProfile",
      "description": "Public user profiles indexed by username"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Postcard likes"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Postcard comments"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/folios/{folioId}": {
      "schema": "Folio",
      "description": "Folio collections"
    },
    "/folio_metadata/{userId}": {
      "schema": "FolioMetadata",
      "description": "Folio-wide metadata and share tokens"
    },
    "/postcards/{postcardId}": {
      "schema": "Postcard",
      "description": "Individual postcards"
    },
    "/shares/{shareId}": {
      "schema": "Share",
      "description": "Access keys and sharing permissions"
    }
  }
}
