rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || 
         (request.auth.token.email == "jess@irudd.com" && request.auth.token.email_verified == true));
    }
    
    function isCurator(data) {
      return isAuthenticated() && 
        (data.creatorId == request.auth.uid || 
         (request.auth.uid in data.get('curatorIds', [])));
    }

    function isCuratorOfCollection(collectionId) {
      let collectionData = get(/databases/$(database)/documents/collections/$(collectionId)).data;
      return isAuthenticated() && 
        (collectionData.creatorId == request.auth.uid || 
         (request.auth.uid in collectionData.get('curatorIds', [])));
    }

    function isInvited(data) {
      return isAuthenticated() && 
        (request.auth.token.email in data.get('allowedUsers', []));
    }

    function isInvitedToCollection(collectionId) {
      let collectionData = get(/databases/$(database)/documents/collections/$(collectionId)).data;
      return isAuthenticated() && 
        (request.auth.token.email in collectionData.get('allowedUsers', []));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Test Collection (for connection test)
    match /test/connection {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Public Profiles
    match /public_profiles/{username} {
      allow read: if true;
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Collections
    match /collections/{collectionId} {
      allow read: if isAdmin() ||
                     resource.data.privacy == 'public' || 
                     resource.data.visibility == 'public' ||
                     isCurator(resource.data) ||
                     isInvited(resource.data) ||
                     (resource.data.folioToken != null); // Allow guest access via token
      
      allow create: if isAuthenticated();
      allow update: if isCurator(resource.data) || isAdmin();
      allow delete: if isCurator(resource.data) || isAdmin();
    }

    // Postcards
    match /postcards/{postcardId} {
      allow read: if isAdmin() ||
                     resource.data.collectionVisibility == 'public' ||
                     resource.data.creatorId == request.auth.uid ||
                     isCuratorOfCollection(resource.data.collectionId) ||
                     resource.data.folioToken != null || // Allow guest access via folio token
                     resource.data.secureToken != null || // Allow guest access via postcard token
                     isInvitedToCollection(resource.data.collectionId);
      
      allow create: if isAuthenticated();
      allow update: if resource.data.creatorId == request.auth.uid || isCuratorOfCollection(resource.data.collectionId) || isAdmin();
      allow delete: if resource.data.creatorId == request.auth.uid || isCuratorOfCollection(resource.data.collectionId) || isAdmin();
    }

    // Shares
    match /shares/{shareId} {
      allow read: if true; // Publicly readable for verification
      allow create: if isAuthenticated();
      allow update, delete: if resource.data.userId == request.auth.uid || isAdmin();
    }

    // Likes
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if resource.data.userId == request.auth.uid || isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Folio Metadata
    match /folio_metadata/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // Folio Tokens
    match /folio_tokens/{token} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Waitlist
    match /waitlist/{email} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
